<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.pknu26.miniright.mapper.BBoardMapper">

    <!-- 검색 조건 -->
    <sql id="searchCondition">
        <where>
            <if test="keyword != null and keyword != ''">
                AND (
                    TITLE LIKE '%' || #{keyword} || '%'
                    OR DBMS_LOB.INSTR(CONTENTS, #{keyword}) > 0
                )
            </if>

            <if test="categoryId != null">
                AND CATEGORY_ID = #{categoryId}
            </if>

            <if test="startDate != null and startDate != ''">
                AND CREATED_AT &gt;= TO_DATE(#{startDate}, 'YYYY-MM-DD')
            </if>

            <if test="endDate != null and endDate != ''">
                AND CREATED_AT &lt; TO_DATE(#{endDate}, 'YYYY-MM-DD') + 1
            </if>
        </where>
    </sql>

    <!-- 검색 + 페이징 목록 조회 -->
    <select id="selectBBoardList" parameterType="PageRequest" resultType="BBoard">
        SELECT *
        FROM (
            SELECT ROWNUM AS RN, T.*
            FROM (
                SELECT
                    POST_ID,
                    CATEGORY_ID,
                    TITLE,
                    CONTENTS,
                    VIEW_COUNT,
                    IMAGE_PATH,
                    CREATED_AT,
                    UPDATED_AT,
                    USER_ID
                FROM B_BOARD
                <include refid="searchCondition" />
                ORDER BY POST_ID DESC
            ) T
            WHERE ROWNUM &lt;= #{offset} + #{size}
        )
        WHERE RN &gt; #{offset}
    </select>

    <!-- 검색 조건에 맞는 전체 개수 -->
    <select id="countBBoardList" parameterType="PageRequest" resultType="int">
        SELECT COUNT(*)
        FROM B_BOARD
        <include refid="searchCondition" />
    </select>

    <!-- 상세 조회 -->
    <select id="findById" parameterType="long" resultType="BBoard">
        SELECT
            POST_ID,
            CATEGORY_ID,
            TITLE,
            CONTENTS,
            VIEW_COUNT,
            IMAGE_PATH,
            CREATED_AT,
            UPDATED_AT,
            USER_ID
        FROM B_BOARD
        WHERE POST_ID = #{postId}
    </select>

    <!-- 작성 -->
    <insert id="insertBBoard" parameterType="BBoard">
        INSERT INTO B_BOARD (
            POST_ID,
            CATEGORY_ID,
            TITLE,
            CONTENTS,
            USER_ID,
            IMAGE_PATH
        ) VALUES (
            B_BOARD_SEQ.NEXTVAL,
            #{categoryId},
            #{title},
            #{contents},
            #{userId},
            #{imagePath}
        )
    </insert>

    <!-- 수정 -->
    <update id="updateBBoard" parameterType="BBoard">
        UPDATE B_BOARD
        SET TITLE = #{title},
            CONTENTS = #{contents},
            CATEGORY_ID = #{categoryId},
            IMAGE_PATH = #{imagePath},
            UPDATED_AT = SYSDATE
        WHERE POST_ID = #{postId}
    </update>

    <!-- 삭제 -->
    <delete id="deleteBBoard" parameterType="long">
        DELETE FROM B_BOARD
        WHERE POST_ID = #{postId}
    </delete>

    <!-- 조회수 증가 -->
    <update id="increaseBViewCount" parameterType="long">
        UPDATE B_BOARD
        SET VIEW_COUNT = NVL(VIEW_COUNT, 0) + 1
        WHERE POST_ID = #{postId}
    </update>

</mapper>