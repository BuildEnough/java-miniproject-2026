<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper 
   PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
   "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.pknu26.miniright.mapper.UserMapper">

    <select id="findByLoginId" parameterType="string" resultType="User">
        SELECT USER_ID,
               LOGIN_ID,
               PASSWORD,
               NAME,
               ROLE,
               CREATED_AT,
               UPDATED_AT
        FROM USERS
        WHERE LOGIN_ID = #{loginId}
    </select>

    <insert id="insertUser" parameterType="User">
        INSERT INTO USERS (
            USER_ID, 
            LOGIN_ID, 
            PASSWORD, 
            NAME, 
            ROLE,
            CREATED_AT
        ) VALUES (
            SEQ_USERS_ID.NEXTVAL,
            #{loginId}, 
            #{password,jdbcType=VARCHAR},
            #{name}, 
            #{role}, 
            SYSDATE
        )
    </insert>

    <select id="nextUserId" resultType="long">
        SELECT SEQ_USER_ID.NEXTVAL FROM DUAL
    </select>

</mapper>