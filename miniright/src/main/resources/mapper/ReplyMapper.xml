<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.pknu26.miniright.mapper.ReplyMapper">

    <!-- 특정 게시글의 답글 목록 조회 -->
    <select id="findByPostId" parameterType="long" resultType="Reply">
        SELECT
            POST_ID,
            REPLY_ID,
            CONTENTS,
            WRITER,
            USER_ID,
            CREATED_AT
        FROM REPLY
        WHERE POST_ID = #{postId}
        ORDER BY REPLY_ID ASC
    </select>

    <select id="getReply" parameterType="long" resultType="Reply">
        SELECT 
            POST_ID,
            REPLY_ID,
            CONTENTS,
            WRITER,
            USER_ID,
            CREATED_AT
        FROM REPLY
        WHERE REPLY_ID = #{replyId}
    </select>

    <!-- 답글 등록 -->
    <insert id="insertReply" parameterType="Reply">
        INSERT INTO REPLY (
            POST_ID,
            REPLY_ID,
            CONTENTS,
            WRITER,
            USER_ID,
            CREATED_AT
        ) VALUES (
            #{postId},
            SEQ_REPLY_ID.NEXTVAL,
            #{contents},
            #{writer},
            #{userId},
            SYSDATE
        )
    </insert>

    <!-- 답글 삭제 -->
    <delete id="deleteReply" parameterType="long">
        DELETE FROM REPLY
        WHERE REPLY_ID = #{replyId}
    </delete>

</mapper>